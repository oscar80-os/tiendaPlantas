rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    match /certificados/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    match /productos/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    match /cursos/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    match /logos/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
